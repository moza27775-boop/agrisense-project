// ===== قراءة المستشعرات =====
void readSensors() {
  // قراءة DHT11
  float newTemp = dht.readTemperature();
  float newHum = dht.readHumidity();
  
  if (!isnan(newTemp)) temp = newTemp;
  if (!isnan(newHum)) hum = newHum;
  
  // قراءة المستشعرات التناظرية
  soil = analogRead(SOIL_PIN);
  gas = analogRead(GAS_PIN);
  light = analogRead(LIGHT_PIN);
  
  // تحويل القيم
  soil = map(soil, 0, 4095, 0, 100);
  light = map(light, 0, 4095, 0, 100);
}

// ===== التحكم في المشغلات =====
void controlRelays() {
  // التحكم في مروحة الحرارة
  if (temp > TEMP_LIMIT) {
    digitalWrite(RELAY_TEMP_FAN, LOW);  // تشغيل
  } else {
    digitalWrite(RELAY_TEMP_FAN, HIGH); // إيقاف
  }
  
  // التحكم في مروحة الغاز
  if (gas > GAS_LIMIT) {
    digitalWrite(RELAY_GAS_FAN, LOW);
  } else {
    digitalWrite(RELAY_GAS_FAN, HIGH);
  }
  
  // التحكم في مضخة الماء (التربة: كلما زاد الرقم كلما كانت أقل رطوبة)
  if (soil < SOIL_LIMIT) {
    digitalWrite(RELAY_PUMP, LOW);  // تشغيل
  } else {
    digitalWrite(RELAY_PUMP, HIGH); // إيقاف
  }
}

// ===== عرض على LCD =====
void updateLCD() {
  lcd.clear();
  
  switch(lcdPage) {
    case 0:
      lcd.setCursor(0, 0);
      lcd.print("Temp:");
      lcd.print(temp, 1);
      lcd.print("C");
      lcd.setCursor(0, 1);
      lcd.print("Hum:");
      lcd.print(hum, 0);
      lcd.print("%");
      break;
    case 1:
      lcd.setCursor(0, 0);
      lcd.print("Soil:");
      lcd.print(soil);
      lcd.print("%");
      lcd.setCursor(0, 1);
      lcd.print("Gas:");
      lcd.print(gas);
      break;
    case 2:
      lcd.setCursor(0, 0);
      lcd.print("Light:");
      lcd.print(light);
      lcd.print("%");
      lcd.setCursor(0, 1);
      lcd.print("IP:");
      lcd.print(WiFi.localIP());
      break;
  }
  
  lcdPage = (lcdPage + 1) % 3;
}

// ===== رفع البيانات لـ Firebase =====
void updateFirebase() {
  if (!Firebase.ready()) {
    firebaseReady = false;
    return;
  }
  
  firebaseReady = true;
  
  Firebase.RTDB.setFloat(&fbdo, "/sensor/temp", temp);
  Firebase.RTDB.setFloat(&fbdo, "/sensor/hum", hum);
  Firebase.RTDB.setInt(&fbdo, "/sensor/soil", soil);
  Firebase.RTDB.setInt(&fbdo, "/sensor/gas", gas);
  Firebase.RTDB.setInt(&fbdo, "/sensor/light", light);
  Firebase.RTDB.setBool(&fbdo, "/relays/fanTemp", digitalRead(RELAY_TEMP_FAN) == LOW);
  Firebase.RTDB.setBool(&fbdo, "/relays/fanGas", digitalRead(RELAY_GAS_FAN) == LOW);
  Firebase.RTDB.setBool(&fbdo, "/relays/pump", digitalRead(RELAY_PUMP) == LOW);
}

void setup() {
  Serial.begin(115200);
  
  // ===== إعداد المشغلات =====
  pinMode(RELAY_TEMP_FAN, OUTPUT);
  pinMode(RELAY_GAS_FAN, OUTPUT);
  pinMode(RELAY_PUMP, OUTPUT);
  
  digitalWrite(RELAY_TEMP_FAN, HIGH);
  digitalWrite(RELAY_GAS_FAN, HIGH);
  digitalWrite(RELAY_PUMP, HIGH);
  
  // ===== إعداد LCD =====
  lcd.init();
  lcd.backlight();
  lcd.setCursor(0, 0);
  lcd.print("Starting...");
  
  // ===== إعداد DHT =====
  dht.begin();
  
  // ===== اتصال WiFi =====
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  lcd.setCursor(0, 1);
  lcd.print("WiFi...");
  
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 25) {
    delay(500);
    attempts++;
  }
  
  lcd.clear();
  if (WiFi.status() == WL_CONNECTED) {
    lcd.setCursor(0, 0);
    lcd.print("WiFi OK");
    lcd.setCursor(0, 1);
    lcd.print(WiFi.localIP());
    delay(2000);
  } else {
    lcd.setCursor(0, 0);
    lcd.print("WiFi Failed");
    delay(2000);
  }
  
  // ===== إعداد Firebase =====
  config.api_key = API_KEY;
  config.database_url = DATABASE_URL;
  config.signer.test_mode = true;
  
  Firebase.begin(&config, &auth);
  Firebase.reconnectWiFi(true);
  
  // ===== إعداد Web Server =====
  server.on("/", HTTP_GET, []() {
    server.send(200, "text/html", index_html);
  });
  
  server.on("/data", HTTP_GET, []() {
    StaticJsonDocument<300> doc;
    doc["temp"] = temp;
    doc["hum"] = hum;
    doc["soil"] = soil;
    doc["gas"] = gas;
    doc["light"] = light;
    doc["firebase"] = firebaseReady;
    doc["fanTemp"] = digitalRead(RELAY_TEMP_FAN) == LOW;
    doc["fanGas"] = digitalRead(RELAY_GAS_FAN) == LOW;
    doc["pump"] = digitalRead(RELAY_PUMP) == LOW;
    
    String response;
    serializeJson(doc, response);
    server.send(200, "application/json", response);
  });
  
  server.on("/toggle", HTTP_GET, []() {
    String relay = server.arg("relay");
    if (relay == "fanTemp") {
      digitalWrite(RELAY_TEMP_FAN, !digitalRead(RELAY_TEMP_FAN));
    }
    server.send(200, "text/plain", "OK");
  });
  
  server.begin();
  
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("System Ready");
  delay(2000);
  
  Serial.println("\n========================================");
  Serial.println("ESP32 Smart Control System");
  Serial.print("IP: "); Serial.println(WiFi.localIP());
  Serial.println("========================================");
}

void loop() {
  server.handleClient();
  
  // قراءة المستشعرات كل ثانية
  static unsigned long lastSensorRead = 0;
  if (millis() - lastSensorRead > 1000) {
    lastSensorRead = millis();
    readSensors();
    controlRelays();
  }
  
  // تحديث LCD كل 3 ثواني
  if (millis() - lastLCDUpdate > 3000) {
    lastLCDUpdate = millis();
    updateLCD();
  }
  
  // رفع لـ Firebase كل 5 ثواني
  if (millis() - lastUpdate > 5000) {
    lastUpdate = millis();
    updateFirebase();
    
    // طباعة في Serial
    Serial.print("T:"); Serial.print(temp);
    Serial.print(" H:"); Serial.print(hum);
    Serial.print(" S:"); Serial.print(soil);
    Serial.print(" G:"); Serial.print(gas);
    Serial.print(" L:"); Serial.println(light);
  }
  
  delay(10);
}